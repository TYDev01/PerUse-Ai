!.env.example

# vercel
.vercel
td.md


# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client
/src/generated/prisma

# IDE / editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.AppleDouble
.LSOverride

